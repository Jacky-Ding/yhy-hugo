/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Cache HTML pages for a short time so updates appear quickly
*.html
  Cache-Control: public, max-age=300, must-revalidate

# Cache CSS / JS — moderate duration, since filenames are not hashed
# (Hugo Pipes fingerprinting would allow a much longer cache)
*.css
  Cache-Control: public, max-age=86400
*.js
  Cache-Control: public, max-age=86400

# Cache images / fonts — they change rarely, so a longer cache is fine
*.jpg
  Cache-Control: public, max-age=2592000
*.jpeg
  Cache-Control: public, max-age=2592000
*.png
  Cache-Control: public, max-age=2592000
*.webp
  Cache-Control: public, max-age=2592000
*.svg
  Cache-Control: public, max-age=2592000
*.ico
  Cache-Control: public, max-age=2592000
*.woff
  Cache-Control: public, max-age=31536000, immutable
*.woff2
  Cache-Control: public, max-age=31536000, immutable
